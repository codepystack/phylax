# Required – 32+ character secret used to protect session vault keys.
# Change this before deploying to production!
SERVER_SECRET=change-me-in-production-server-secret-key

# SQLite database path (relative to the backend/ directory when running the server)
DATABASE_URL=sqlite://phylax.db

# Logging level (trace, debug, info, warn, error)
RUST_LOG=phylax_server=info,tower_http=info
